#!/usr/bin/env bash
# World Chain pre-commit hook
# Install: cargo xtask install-hooks

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
GRAY='\033[0;90m'
NC='\033[0m'

fix()   { echo -e "${YELLOW}FIX ${NC} $1"; }
pass()  { echo -e "${GREEN}PASS${NC} $1"; }
fail()  { echo -e "${RED}FAIL${NC} $1"; }
skip()  { echo -e "${GRAY}SKIP${NC} $1"; }

echo "Running pre-commit checks..."
echo

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

errors=0

# --- Phase 1: Auto-fix in parallel ---

# 1a. Rust formatting — fix then re-stage
(
    cargo +nightly fmt --all 2>/dev/null \
        && echo "fixed" > "$TMPDIR/fmt" \
        || echo "fail" > "$TMPDIR/fmt"
) &

# 1b. Clippy auto-fix
(
    cargo +nightly clippy --workspace --all-targets --all-features \
        --fix --allow-dirty --allow-staged --quiet 2>/dev/null \
        && echo "fixed" > "$TMPDIR/clippy_fix" \
        || echo "fail" > "$TMPDIR/clippy_fix"
) &

# 1c. Solidity formatting — only if contracts/ changed
(
    if git diff --cached --name-only | grep -q '^contracts/'; then
        cd contracts && forge fmt 2>/dev/null \
            && echo "fixed" > "$TMPDIR/forge_fix" \
            || echo "fail" > "$TMPDIR/forge_fix"
    else
        echo "skip" > "$TMPDIR/forge_fix"
    fi
) &

wait

# Re-stage any auto-fixed files
git diff --name-only | xargs -r git add 2>/dev/null || true

# --- Phase 2: Verify in parallel ---

# 2a. Rust format check (should pass after fix)
(
    cargo +nightly fmt --all -- --check 2>/dev/null \
        && echo "pass" > "$TMPDIR/fmt_check" \
        || echo "fail" > "$TMPDIR/fmt_check"
) &

# 2b. Clippy check (should pass after fix)
(
    RUSTFLAGS="-D warnings" cargo +nightly clippy \
        --workspace --all-targets --all-features --quiet 2>/dev/null \
        && echo "pass" > "$TMPDIR/clippy_check" \
        || echo "fail" > "$TMPDIR/clippy_check"
) &

# 2c. CLI docs — only if the CLI crate was modified
(
    if git diff --cached --name-only | grep -q '^crates/world-chain-cli/'; then
        cargo xtask docs 2>/dev/null || cargo run -p xtask --quiet -- docs 2>/dev/null
        if git diff --quiet specs/; then
            echo "pass" > "$TMPDIR/docs"
        else
            git checkout -- specs/ 2>/dev/null || true
            echo "fail" > "$TMPDIR/docs"
        fi
    else
        echo "skip" > "$TMPDIR/docs"
    fi
) &

# 2d. Solidity format check — only if contracts/ changed
(
    if git diff --cached --name-only | grep -q '^contracts/'; then
        cd contracts && forge fmt --check 2>/dev/null \
            && echo "pass" > "$TMPDIR/forge_check" \
            || echo "fail" > "$TMPDIR/forge_check"
    else
        echo "skip" > "$TMPDIR/forge_check"
    fi
) &

wait

# --- Report results ---

result_fmt=$(cat "$TMPDIR/fmt_check" 2>/dev/null || echo "fail")
if [ "$result_fmt" = "pass" ]; then
    # Check if we actually fixed anything
    if [ "$(cat "$TMPDIR/fmt" 2>/dev/null)" = "fixed" ]; then
        fix "Rust formatting (auto-fixed & staged)"
    else
        pass "Rust formatting"
    fi
else
    fail "Rust formatting — auto-fix failed"
    errors=$((errors + 1))
fi

result_clippy=$(cat "$TMPDIR/clippy_check" 2>/dev/null || echo "fail")
if [ "$result_clippy" = "pass" ]; then
    if [ "$(cat "$TMPDIR/clippy_fix" 2>/dev/null)" = "fixed" ]; then
        fix "Clippy (auto-fixed & staged)"
    else
        pass "Clippy"
    fi
else
    fail "Clippy — auto-fix insufficient, manual fixes needed"
    errors=$((errors + 1))
fi

result_docs=$(cat "$TMPDIR/docs" 2>/dev/null || echo "fail")
if [ "$result_docs" = "pass" ]; then
    pass "CLI docs up to date"
elif [ "$result_docs" = "skip" ]; then
    skip "CLI docs (world-chain-cli unchanged)"
else
    fail "CLI docs are stale — run 'cargo xtask docs' and stage the changes"
    errors=$((errors + 1))
fi

result_forge=$(cat "$TMPDIR/forge_check" 2>/dev/null || echo "fail")
if [ "$result_forge" = "pass" ]; then
    forge_fix=$(cat "$TMPDIR/forge_fix" 2>/dev/null || echo "")
    if [ "$forge_fix" = "fixed" ]; then
        fix "Solidity formatting (auto-fixed & staged)"
    else
        pass "Solidity formatting"
    fi
elif [ "$result_forge" = "skip" ]; then
    skip "Solidity formatting (contracts/ unchanged)"
else
    fail "Solidity formatting — auto-fix failed"
    errors=$((errors + 1))
fi

echo
if [ "$errors" -gt 0 ]; then
    echo -e "${RED}$errors check(s) failed.${NC}"
    exit 1
fi
echo -e "${GREEN}All pre-commit checks passed.${NC}"
