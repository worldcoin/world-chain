# Sample environment for `nitro-worker`. Copy to `.env` and edit; `dotenvy` is loaded at
# startup. All flags can also be passed on the command line. See `README.md` for details.

# --- prover-service queue ------------------------------------------------------------------
PROVER_SERVICE_URL=http://127.0.0.1:8551

# --- chain RPCs -----------------------------------------------------------------------------
L1_RPC_URL=http://127.0.0.1:8545
L1_BEACON_RPC_URL=http://127.0.0.1:8545
L2_RPC_URL=http://127.0.0.1:8546

# --- network identity -----------------------------------------------------------------------
# `worldchain` for mainnet (chain id 480), `worldchain-sepolia` for testnet (chain id 4801).
NETWORK=worldchain
# Optional: override the rollup config and its hash. Leave unset to use the built-in network
# config.
# ROLLUP_CONFIG=/path/to/rollup.json
# ROLLUP_CONFIG_HASH=0x...

# L2 blocks between a proposal's parent and its claimed block (proof system `blockInterval`).
BLOCK_INTERVAL=10

# --- enclave endpoint ----------------------------------------------------------------------
# vsock CID/port of the running Nitro Enclave. CID 16 is the default for `nitro-cli run-enclave`
# in most environments; 5005 is the worker's default port.
ENCLAVE_CID=16
ENCLAVE_PORT=5005

# --- attestation pinning -------------------------------------------------------------------
# Production REQUIRES all three. Devnet may leave them unset together with NITRO_WORKER_DEV=1,
# which falls back to placeholder zeros (attestation/signature verification is SKIPPED).
# PCR0=
# PCR1=
# PCR2=
# NITRO_WORKER_DEV=1

# --- runtime knobs --------------------------------------------------------------------------
POLL_INTERVAL_SECONDS=10

# --- logging --------------------------------------------------------------------------------
RUST_LOG=info,world_chain_nitro_worker=info
