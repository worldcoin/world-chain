# Justfile for the Nitro verifier guest ELF build.
#
# These recipes are invoked by the Dockerfile (see README.md). Do not run
# them directly on the host — production builds must use Docker to guarantee
# reproducibility across machines.

# Guest binary name (hyphens become underscores in the compiled binary)
guest := "base-proof-tee-nitro-verifier-guest"

# Expected risc0 toolchain version. Update these when bumping the toolchain.
# Must match RISC0_RUST_VERSION / RISC0_RUST_COMMIT in the Dockerfile.
expected_risc0_rust := "1.91.1"
expected_risc0_commit := "30e2186d0"

# Repo root (resolved via git so the path doesn't break if the crate moves).
repo_root := `git rev-parse --show-toplevel`

# Cargo registry cache (defaults to ~/.cargo)
cargo_home := env("CARGO_HOME", home_directory() / ".cargo")

# Remap absolute paths so the ELF (and image ID) is identical regardless of
# where the repo is checked out or where the Cargo registry lives.
# NOTE: repo_root and cargo_home must not contain spaces — rustc splits
# RUSTFLAGS on whitespace, which would break the remap arguments.
remap_flags := "--remap-path-prefix=" + repo_root + "=/build --remap-path-prefix=" + cargo_home + "=/registry"

# Default recipe to display help information
default:
    @just --list

# Verify the risc0 toolchain is installed and matches the expected version.
[private]
check-toolchain:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! rustc +risc0 --version > /dev/null 2>&1; then
        echo "error: risc0 toolchain not found. Run 'rzup install' first." >&2
        exit 1
    fi
    version=$(rustc +risc0 --version)
    if [[ "$version" != *"{{ expected_risc0_commit }}"* ]]; then
        echo "error: risc0 toolchain version mismatch." >&2
        echo "  expected commit: {{ expected_risc0_commit }}" >&2
        echo "  got:             $version" >&2
        echo "" >&2
        echo "Run 'rzup install rust {{ expected_risc0_rust }}' to install the correct version," >&2
        echo "or update expected_risc0_commit in the Justfile if you intentionally" >&2
        echo "bumped the toolchain." >&2
        exit 1
    fi

# Build the guest ELF with the risc0 toolchain.
#
# Reproducibility note: Cargo includes the absolute path of path
# dependencies in its -C metadata hash, which feeds into symbol mangling.
# This is fine as long as builds always run inside Docker where the repo
# is bind-mounted at a fixed path (/build/base). Do not build natively.
build: check-toolchain
    RUSTFLAGS='--cfg getrandom_backend="custom" {{ remap_flags }}' \
        cargo +risc0 build --release --target riscv32im-risc0-zkvm-elf --ignore-rust-version
    @echo "ELF built at: target/riscv32im-risc0-zkvm-elf/release/{{ guest }}"
    @ls -lh target/riscv32im-risc0-zkvm-elf/release/{{ guest }}

# Bundle the raw ELF into R0BF format and compute the image ID.
# Outputs the bundled file and prints the image ID to use for
# --image-id and the on-chain contract.
bundle: build
    @echo "Bundling ELF into R0BF format and computing image ID..."
    RISC0_SKIP_BUILD_KERNELS=1 cargo run \
        --manifest-path tools/compute-image-id/Cargo.toml -- \
        target/riscv32im-risc0-zkvm-elf/release/{{ guest }} \
        --output target/{{ guest }}.r0bf

# Build, verify, and optionally compare against a remote IPFS upload.
# If build artifacts don't exist yet, automatically runs the full build
# first. Prints the ELF hash, R0BF hash, and image ID. If an IPFS URL
# is provided, downloads the remote R0BF and checks it matches the
# local bundle.
#
# Usage:
#   just verify                     # build (if needed) + local hashes
#   just verify "https://..."       # also compare against IPFS
verify ipfs_url="":
    #!/usr/bin/env bash
    set -euo pipefail
    elf="target/riscv32im-risc0-zkvm-elf/release/{{ guest }}"
    r0bf="target/{{ guest }}.r0bf"
    if [ ! -f "$elf" ] || [ ! -f "$r0bf" ]; then
        echo "Build artifacts not found — running full build..."
        echo ""
        just bundle
        echo ""
    fi
    echo "=== Raw ELF hash ==="
    sha256sum "$elf"
    echo ""
    echo "=== R0BF bundle hash ==="
    sha256sum "$r0bf"
    echo ""
    echo "=== Image ID ==="
    RISC0_SKIP_BUILD_KERNELS=1 cargo run -q \
        --manifest-path tools/compute-image-id/Cargo.toml -- "$elf" 2>&1 \
        | grep "Image ID"
    if [ -n "{{ ipfs_url }}" ]; then
        echo ""
        echo "=== Remote IPFS comparison ==="
        tmp=$(mktemp)
        curl -fsSL -o "$tmp" "{{ ipfs_url }}"
        remote_hash=$(sha256sum "$tmp" | cut -d' ' -f1)
        local_hash=$(sha256sum "$r0bf" | cut -d' ' -f1)
        rm "$tmp"
        echo "Local R0BF:  $local_hash"
        echo "Remote R0BF: $remote_hash"
        if [ "$local_hash" = "$remote_hash" ]; then
            echo "MATCH — remote IPFS file is identical to local build."
        else
            echo "MISMATCH — remote IPFS file differs from local build!" >&2
            exit 1
        fi
    fi

# Install the pinned risc0 toolchain via rzup
install-toolchain:
    rzup install rust {{ expected_risc0_rust }}

# Dump build environment for cross-machine reproducibility debugging.
# Compare the output between machines to identify non-determinism sources.
diagnose: check-toolchain
    #!/usr/bin/env bash
    set -euo pipefail
    echo "=== Git ==="
    echo "commit: $(git rev-parse HEAD)"
    echo "branch: $(git rev-parse --abbrev-ref HEAD)"
    echo "dirty:  $(git status --porcelain -- . ../../nitro-verifier | head -5)"
    echo ""
    echo "=== Toolchain ==="
    echo "rustc:  $(rustc +risc0 --version --verbose 2>&1)"
    echo "cargo:  $(cargo +risc0 --version)"
    echo "rustc-hash: $(shasum -a 256 "$(rustup +risc0 which rustc)" 2>/dev/null || sha256sum "$(rustup +risc0 which rustc)")"
    echo ""
    echo "=== RUSTFLAGS ==="
    echo '--cfg getrandom_backend="custom" {{ remap_flags }}'
    echo ""
    echo "=== Cargo.lock hash ==="
    shasum -a 256 Cargo.lock 2>/dev/null || sha256sum Cargo.lock
    echo ""
    echo "=== Cargo.toml hash ==="
    shasum -a 256 Cargo.toml 2>/dev/null || sha256sum Cargo.toml
    echo ""
    echo "=== Source hashes ==="
    find src -type f | sort | xargs shasum -a 256 2>/dev/null || find src -type f | sort | xargs sha256sum
    echo ""
    echo "=== Verifier crate source hashes ==="
    find ../../nitro-verifier/src -type f | sort | xargs shasum -a 256 2>/dev/null || find ../../nitro-verifier/src -type f | sort | xargs sha256sum
    echo ""
    echo "=== Build config hashes ==="
    shasum -a 256 Justfile 2>/dev/null || sha256sum Justfile
    shasum -a 256 Dockerfile 2>/dev/null || sha256sum Dockerfile
    echo ""
    echo "=== Profile settings ==="
    grep -A5 '\[profile' Cargo.toml || true

# Clean build artifacts
clean:
    cargo clean
    rm -rf tools/compute-image-id/target/
